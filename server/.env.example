# Gmail SMTP (use an App Password: Google Account → Security → 2-Step Verification → App passwords)
# Outbound TCP 587 to smtp.gmail.com must be allowed (some networks block it).
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Where enquiry emails are delivered (defaults to GMAIL_USER if omitted)
MAIL_TO=info@example.com

# If Node errors with "self-signed certificate in certificate chain" (often corporate Wi‑Fi / antivirus SSL scanning):
# - Prefer: install your organisation root CA and run Node with NODE_EXTRA_CA_CERTS=C:\path\to\ca.pem
# - Dev only: SMTP_TLS_INSECURE=true   (disables TLS verification — do not use in production)

PORT=3001
